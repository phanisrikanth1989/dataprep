    <routinesParameter id="_MCLIcPPtEfC_ULB-46VDCQ" name="TalendDate"/>
    <routinesParameter id="_MCQA8PPtEfC_ULB-46VDCQ" name="TalendStringUtil"/>
    <routinesParameter id="_MCNksPPtEfC_ULB-46VDCQ" name="TalendString"/>
  </parameters>
<context confirmationNeeded="false" name="Default">
    <contextParameter name="inputFile" type="id_String" value="&quot;data/employees.csv&quot;"/>
    <contextParameter name="logFile" type="id_String" value="&quot;data/job_log.txt&quot;"/>
  </context>

  
  <node componentName="tPreJob" componentVersion="0.101" posX="128" posY="64">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tPreJob_1"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;PreJob_Start&quot;"/>
  </node>

  <node componentName="tJava" componentVersion="0.101" posX="320" posY="64">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Setup_Logging&quot;"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="
// Pre-job setup: Initialize logging, create directories
System.out.println(&quot;[PRE-JOB] Job started at: &quot; + java.time.LocalDateTime.now());
System.out.println(&quot;[PRE-JOB] Input file: &quot; + context.inputFile);

// Create output directory if not exists
java.io.File logDir = new java.io.File(context.logFile).getParentFile();
if (logDir != null &amp;&amp; !logDir.exists()) {
    logDir.mkdirs();
    System.out.println(&quot;[PRE-JOB] Created directory: &quot; + logDir.getAbsolutePath());
}

// Store start time in globalMap for PostJob
globalMap.put(&quot;startTime&quot;, System.currentTimeMillis());
System.out.println(&quot;[PRE-JOB] Setup complete.&quot;);
"/>
  </node>

  
  <node componentName="tFileInputDelimited" componentVersion="0.101" posX="128" posY="200">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tFileInputDelimited_1"/>
    <elementParameter field="FILE" name="FILENAME" value="context.inputFile"/>
    <elementParameter field="TEXT" name="FIELDSEPARATOR" value="&quot;;&quot;"/>
    <elementParameter field="CHECK" name="HEADER" value="true"/>
    <elementParameter field="TEXT" name="HEADER_VALUE" value="1"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Read_Input&quot;"/>
    <metadata connector="FLOW" name="tFileInputDelimited_1">
      <column name="id" type="id_Integer"/>
      <column name="name" type="id_String" length="100"/>
      <column name="department" type="id_String" length="50"/>
      <column name="salary" type="id_Integer"/>
    </metadata>
  </node>

  <node componentName="tLogRow" componentVersion="0.101" posX="384" posY="200">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tLogRow_1"/>
    <elementParameter field="CLOSED_LIST" name="BASIC_MODE" value="TABLE"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Display_Data&quot;"/>
  </node>

  
  <node componentName="tPostJob" componentVersion="0.101" posX="128" posY="336">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tPostJob_1"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;PostJob_Start&quot;"/>
  </node>

  <node componentName="tJava" componentVersion="0.101" posX="320" posY="336">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_2"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Cleanup_Summary&quot;"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="
// Post-job cleanup: Log summary, cleanup temp files
long startTime = (Long) globalMap.get(&quot;startTime&quot;);
long duration = System.currentTimeMillis() - startTime;

System.out.println(&quot;[POST-JOB] Job completed at: &quot; + java.time.LocalDateTime.now());
System.out.println(&quot;[POST-JOB] Duration: &quot; + duration + &quot; ms&quot;);
System.out.println(&quot;[POST-JOB] Cleanup complete.&quot;);
"/>
  </node>

  
  <connection connectorName="COMPONENT_OK" label="OnSubjobOk" lineStyle="2"
              source="tPreJob_1" target="tJava_1"/>
  <connection connectorName="FLOW" label="row1" lineStyle="0"
              source="tFileInputDelimited_1" target="tLogRow_1"/>
  <connection connectorName="COMPONENT_OK" label="OnSubjobOk" lineStyle="2"
              source="tPostJob_1" target="tJava_2"/>
  <subjob>
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tPreJob_1" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_TITLE_COLOR" value="92;131;150" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_COLOR" value="207;226;236"/>
  </subjob>
</talendfile:ProcessType>
