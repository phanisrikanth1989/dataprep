  <node componentName="tLoop" componentVersion="0.101" posX="128" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tLoop_1"/>
    <elementParameter field="TEXT" name="FROM" value="1"/>
    <elementParameter field="TEXT" name="TO" value="context.loopCount"/>
    <elementParameter field="TEXT" name="STEP" value="1"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Loop_1_to_N&quot;"/>
  </node>

  
  <node componentName="tJava" componentVersion="0.101" posX="320" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Process_Iteration&quot;"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="
// Access current loop value
int currentIndex = (Integer) globalMap.get(&quot;tLoop_1_CURRENT_VALUE&quot;);
System.out.println(&quot;Processing iteration: &quot; + currentIndex);
System.out.println(&quot;  Generating report for batch #&quot; + currentIndex);

// Simulate work: file name based on loop index
String fileName = &quot;batch_&quot; + String.format(&quot;%03d&quot;, currentIndex) + &quot;.csv&quot;;
System.out.println(&quot;  Output file: &quot; + fileName);
"/>
  </node>

  
  <connection connectorName="ITERATE" label="iterate1" lineStyle="0"
              source="tLoop_1" target="tJava_1"/>
  <subjob>
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tLoop_1" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_TITLE_COLOR" value="92;131;150" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_COLOR" value="207;226;236"/>
  </subjob>
