<node componentName="tFileInputDelimited" componentVersion="0.101" posX="64" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tFileInputDelimited_1"/>
    <elementParameter field="FILE" name="FILENAME" value="&quot;data/quarterly_sales.csv&quot;"/>
    <elementParameter field="TEXT" name="FIELDSEPARATOR" value="&quot;;&quot;"/>
    <elementParameter field="CHECK" name="HEADER" value="true"/>
    <elementParameter field="TEXT" name="HEADER_VALUE" value="1"/>
    <metadata connector="FLOW" name="tFileInputDelimited_1">
      <column name="employee" type="id_String" length="100"/>
      <column name="Q1_sales" type="id_Integer"/>
      <column name="Q2_sales" type="id_Integer"/>
      <column name="Q3_sales" type="id_Integer"/>
      <column name="Q4_sales" type="id_Integer"/>
    </metadata>
  </node>

  
  <node componentName="tUnpivot" componentVersion="0.101" posX="288" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tUnpivot_1"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Unpivot_Quarters&quot;"/>
    
    <elementParameter field="TABLE" name="SCHEMA_UNPIVOT">
      <elementValue elementRef="INPUT_COLUMN" value="Q1_sales"/>
      <elementValue elementRef="UNPIVOT" value="true"/>
    </elementParameter>
    <elementParameter field="TABLE" name="SCHEMA_UNPIVOT">
      <elementValue elementRef="INPUT_COLUMN" value="Q2_sales"/>
      <elementValue elementRef="UNPIVOT" value="true"/>
    </elementParameter>
    <elementParameter field="TABLE" name="SCHEMA_UNPIVOT">
      <elementValue elementRef="INPUT_COLUMN" value="Q3_sales"/>
      <elementValue elementRef="UNPIVOT" value="true"/>
    </elementParameter>
    <elementParameter field="TABLE" name="SCHEMA_UNPIVOT">
      <elementValue elementRef="INPUT_COLUMN" value="Q4_sales"/>
      <elementValue elementRef="UNPIVOT" value="true"/>
    </elementParameter>
    <elementParameter field="TEXT" name="LABEL_COLUMN" value="&quot;quarter&quot;"/>
    <elementParameter field="TEXT" name="VALUE_COLUMN" value="&quot;sales&quot;"/>
    <metadata connector="FLOW" name="tUnpivot_1">
      <column name="employee" type="id_String" length="100"/>
      <column name="quarter" type="id_String" length="50"/>
      <column name="sales" type="id_String" length="50"/>
    </metadata>
  </node>

  <node componentName="tLogRow" componentVersion="0.101" posX="480" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tLogRow_1"/>
    <elementParameter field="CLOSED_LIST" name="BASIC_MODE" value="TABLE"/>
  </node>

  <connection connectorName="FLOW" label="row1" source="tFileInputDelimited_1" target="tUnpivot_1"/>
  <connection connectorName="FLOW" label="unpivoted" source="tUnpivot_1" target="tLogRow_1"/>
  <subjob>
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tFileInputDelimited_1" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_TITLE_COLOR" value="92;131;150" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_COLOR" value="207;226;236"/>
