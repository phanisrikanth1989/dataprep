    <routinesParameter id="_MCNksPPtEfC_ULB-46VDCQ" name="TalendString"/>
  </parameters>
<context confirmationNeeded="false" name="Default">
    <contextParameter name="excelFile" type="id_String" value="&quot;data/sales_data.xlsx&quot;"/>
  </context>

  
  <node componentName="tFileInputExcel" componentVersion="0.101"
        posX="128" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tFileInputExcel_1"/>
    <elementParameter field="FILE" name="FILENAME" value="context.excelFile"/>
    <elementParameter field="TEXT" name="SHEET_NAME" value="&quot;Sheet1&quot;"/>
    <elementParameter field="CHECK" name="HEADER" value="true"/>
    <elementParameter field="TEXT" name="HEADER_VALUE" value="1"/>
    <elementParameter field="TEXT" name="FIRST_COLUMN" value="0"/>
    <elementParameter field="TEXT" name="LAST_COLUMN" value="5"/>
    <elementParameter field="TEXT" name="LABEL" value="&quot;Read_Sales_Excel&quot;"/>
    <metadata connector="FLOW" name="tFileInputExcel_1">
      <column name="sale_id" type="id_Integer"/>
      <column name="product" type="id_String" length="100"/>
      <column name="region" type="id_String" length="50"/>
      <column name="quantity" type="id_Integer"/>
      <column name="revenue" type="id_Double"/>
      <column name="sale_date" type="id_Date" pattern="yyyy-MM-dd"/>
    </metadata>
  </node>

  
  <node componentName="tLogRow" componentVersion="0.101"
        posX="384" posY="160">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tLogRow_1"/>
    <elementParameter field="CLOSED_LIST" name="BASIC_MODE" value="TABLE"/>
    <metadata connector="FLOW" name="tLogRow_1">
      <column name="sale_id" type="id_Integer"/>
      <column name="product" type="id_String"/>
      <column name="region" type="id_String"/>
      <column name="quantity" type="id_Integer"/>
      <column name="revenue" type="id_Double"/>
      <column name="sale_date" type="id_Date"/>
    </metadata>
  </node>

  <connection connectorName="FLOW" label="row1" lineStyle="0"
              source="tFileInputExcel_1" target="tLogRow_1"/>
  <subjob>
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tFileInputExcel_1" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_TITLE_COLOR" value="92;131;150" show="false"/>
    <elementParameter field="COLOR" name="SUBJOB_COLOR" value="207;226;236"/>
  </subjob>
</talendfile:ProcessType>
