  <node componentName="tJavaFlex" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="416" posY="96">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaFlex_1" show="false"/>
    <elementParameter field="CHECK" name="DATA_AUTO_PROPAGATE" value="true"/>
    <elementParameter field="MEMO_JAVA" name="CODE_START" value="int totalCount = 0;&#xA;int successCount = 0;&#xA;int errorCount = 0;&#xA;&#xA;java.text.SimpleDateFormat inputDateFormat =&#xA;    new java.text.SimpleDateFormat(&quot;yyyy-MM-dd&quot;);&#xA;&#xA;java.text.SimpleDateFormat outputDateFormat =&#xA;    new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;);&#xA;&#xA;inputDateFormat.setLenient(false);&#xA;&#xA;System.out.println(&quot;Job started: &quot; + new java.util.Date());"/>
    <elementParameter field="MEMO_JAVA" name="CODE_MAIN" value="totalCount++;&#xA;&#xA;String errorReason = null;&#xA;&#xA;String customerId = row1.customer_id;&#xA;String name = row1.name;&#xA;String email = row1.email;&#xA;Double amountStr = row1.amount;&#xA;&#xA;java.util.Date orderDate = row1.order_date;&#xA;String orderDateStr = orderDate == null ? null : inputDateFormat.format(orderDate);&#xA;&#xA;Double amount = null;&#xA;&#xA;// --------------------&#xA;// Validation&#xA;// --------------------&#xA;if (customerId == null || customerId.trim().isEmpty()) {&#xA;    errorReason = &quot;Customer ID is missing&quot;;&#xA;} else if (name == null || name.trim().isEmpty()) {&#xA;    errorReason = &quot;Name is missing&quot;;&#xA;} else if (email == null || email.trim().isEmpty()) {&#xA;    errorReason = &quot;Email is missing&quot;;&#xA;} else if (!email.matches(&quot;^[A-Za-z0-9+_.-]+@[A-Za-z0-9.-]+$&quot;)) {&#xA;    errorReason = &quot;Invalid email format&quot;;&#xA;} else if (amountStr == null ) {&#xA;    errorReason = &quot;Amount is missing&quot;;&#xA;} else if (orderDate == null) {&#xA;    errorReason = &quot;Order date is missing&quot;;&#xA;}&#xA;&#xA;// --------------------&#xA;// Amount check&#xA;// --------------------&#xA;if (errorReason == null) {&#xA;    try {&#xA;        amount = amountStr;&#xA;&#xA;        if (amount &lt;= 0) {&#xA;            errorReason = &quot;Amount must be greater than zero&quot;;&#xA;        }&#xA;&#xA;    } catch (Exception e) {&#xA;        errorReason = &quot;Invalid amount: &quot; + amountStr;&#xA;    }&#xA;}&#xA;&#xA;// --------------------&#xA;// Output assignment&#xA;// --------------------&#xA;row2.customer_id = customerId;&#xA;row2.name = name;&#xA;row2.email = email;&#xA;row2.amount = amount;&#xA;row2.order_date = orderDate;&#xA;row2.processed_time = outputDateFormat.format(new java.util.Date());&#xA;&#xA;if (errorReason == null) {&#xA;    successCount++;&#xA;&#xA;    row2.is_valid = true;&#xA;    row2.error_reason = null;&#xA;    row2.status = amount >= 1000 ? &quot;HIGH_VALUE&quot; : &quot;NORMAL&quot;;&#xA;&#xA;    row2.customer_id = customerId.trim();&#xA;    row2.name = name.trim().toUpperCase();&#xA;    row2.email = email.trim().toLowerCase();&#xA;&#xA;} else {&#xA;    errorCount++;&#xA;&#xA;    row2.is_valid = false;&#xA;    row2.error_reason = errorReason;&#xA;    row2.status = &quot;INVALID&quot;;&#xA;}"/>
    <elementParameter field="MEMO_JAVA" name="CODE_END" value="System.out.println(&quot;Job finished: &quot; + new java.util.Date());&#xA;System.out.println(&quot;Total records  : &quot; + totalCount);&#xA;System.out.println(&quot;Success records: &quot; + successCount);&#xA;System.out.println(&quot;Error records  : &quot; + errorCount);"/>
    <elementParameter field="CHECK" name="Version_V2_0" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V3_2" value="false" show="false"/>
    <elementParameter field="CHECK" name="Version_V4.0" value="true" show="false"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
