      <column comment="" key="false" length="-1" name="error_reason" nullable="true" pattern="" precision="-1" sourceType="" type="id_String" originalLength="-1" usefulColumn="true"/>
    </metadata>
    <nodeData xsi:type="TalendMapper:MapperData">
      <uiProperties shellMaximized="true"/>
      <varTables sizeState="INTERMEDIATE" name="Var">
        <mapperTableEntries name="isAmountValid" expression="row1.amount != null &#xA;&amp;&amp; !row1.amount.trim().isEmpty() &#xA;&amp;&amp; row1.amount.trim().matches(&quot;^[0-9]+(\\.[0-9]+)?$&quot;)&#xA;&amp;&amp; Double.parseDouble(row1.amount.trim()) > 0" type="id_Boolean"/>
        <mapperTableEntries name="isDateValid" expression="row1.order_date != null &#xA;&amp;&amp; !row1.order_date.trim().isEmpty() &#xA;&amp;&amp; row1.order_date.trim().matches(&quot;^\\d{4}-\\d{2}-\\d{2}$&quot;)" type="id_Boolean"/>
        <mapperTableEntries name="isEmailValid" expression="row1.email != null &#xA;&amp;&amp; !row1.email.trim().isEmpty() &#xA;&amp;&amp; row1.email.matches(&quot;^[A-Za-z0-9+_.-]+@[A-Za-z0-9.-]+$&quot;)" type="id_Boolean"/>
        <mapperTableEntries name="errorReason" expression="row1.customer_id == null || row1.customer_id.trim().isEmpty() ? &quot;Customer ID is missing&quot; :&#xD;&#xA;row1.name == null || row1.name.trim().isEmpty() ? &quot;Name is missing&quot; :&#xD;&#xA;row1.email == null || row1.email.trim().isEmpty() ? &quot;Email is missing&quot; :&#xD;&#xA;!Var.isEmailValid ? &quot;Invalid email format&quot; :&#xD;&#xA;row1.amount == null || row1.amount.trim().isEmpty() ? &quot;Amount is missing&quot; :&#xD;&#xA;!Var.isAmountValid ? &quot;Invalid amount or amount must be greater than zero&quot; :&#xD;&#xA;row1.order_date == null || row1.order_date.trim().isEmpty() ? &quot;Order date is missing&quot; :&#xD;&#xA;!Var.isDateValid ? &quot;Invalid order date. Expected yyyy-MM-dd&quot; :&#xD;&#xA;null " type="id_String"/>
        <mapperTableEntries name="isValid" expression="Var.errorReason == null" type="id_Boolean"/>
      </varTables>
      <outputTables sizeState="INTERMEDIATE" name="out">
        <mapperTableEntries name="source_file" expression="(String)globalMap.get(&quot;tForeach_1_CURRENT_VALUE&quot;)" type="id_String" nullable="true"/>
        <mapperTableEntries name="customer_id" expression="row1.customer_id == null ? null : row1.customer_id.trim()" type="id_String" nullable="true"/>
        <mapperTableEntries name="name" expression="Var.isValid ? row1.name.trim().toUpperCase() : row1.name" type="id_String" nullable="true"/>
        <mapperTableEntries name="email" expression="Var.isValid ? row1.email.trim().toLowerCase() : row1.email" type="id_String" nullable="true"/>
        <mapperTableEntries name="amount" expression="Var.isAmountValid ? Double.parseDouble(row1.amount) : null" type="id_Double" nullable="true"/>
        <mapperTableEntries name="order_date" expression="Var.isDateValid ? TalendDate.parseDate(&quot;yyyy-MM-dd&quot;, row1.order_date.trim()) : null" type="id_Date" nullable="true"/>
        <mapperTableEntries name="status" expression="Var.isValid &#xA;? (Double.parseDouble(row1.amount.trim()) >= 1000 ? &quot;HIGH_VALUE&quot; : &quot;NORMAL&quot;) &#xA;: &quot;INVALID&quot;" type="id_String" nullable="true"/>
        <mapperTableEntries name="processed_time" expression="TalendDate.formatDate(&quot;yyyy-MM-dd HH:mm:ss&quot;, TalendDate.getCurrentDate())" type="id_String" nullable="true"/>
        <mapperTableEntries name="is_valid" expression="Var.isValid" type="id_Boolean" nullable="true"/>
        <mapperTableEntries name="error_reason" expression="Var.errorReason" type="id_String" nullable="true"/>
      </outputTables>
      <inputTables sizeState="INTERMEDIATE" name="row1" matchingMode="UNIQUE_MATCH" lookupMode="LOAD_ONCE">
        <mapperTableEntries name="customer_id" type="id_String" nullable="true"/>
        <mapperTableEntries name="name" type="id_String" nullable="true"/>
        <mapperTableEntries name="email" type="id_String" nullable="true"/>
        <mapperTableEntries name="amount" type="id_String" nullable="true"/>
        <mapperTableEntries name="order_date" type="id_String" nullable="true"/>
      </inputTables>
    </nodeData>
  </node>
