{
  "schema": {
    "trades": [
      { "name": "trade_id", "type": "string", "nullable": false, "key": true },
      { "name": "account_id", "type": "string", "nullable": false, "key": false },
      { "name": "symbol", "type": "string", "nullable": false, "key": false },
      { "name": "quantity", "type": "integer", "nullable": false, "key": false },
      { "name": "price", "type": "decimal", "nullable": false, "key": false },
      { "name": "status", "type": "string", "nullable": false, "key": false },
      { "name": "trade_date", "type": "date", "nullable": false, "key": false }
    ],
    "accounts": [
      { "name": "account_id", "type": "string", "nullable": false, "key": true },
      { "name": "account_name", "type": "string", "nullable": false, "key": false },
      { "name": "region", "type": "string", "nullable": false, "key": false }
    ],
    "prices": [
      { "name": "symbol", "type": "string", "nullable": false, "key": true },
      { "name": "closing_price", "type": "decimal", "nullable": false, "key": false }
    ]
  },
  "rules": [
    {
      "id": "R1",
      "kind": "join",
      "description": "Left join each trade to Accounts on account_id to add account_name and region; keep unmatched trades with blank account_name and region.",
      "source": "trades",
      "lookup": "accounts",
      "keys": { "left": ["account_id"], "right": ["account_id"] },
      "columns_added": ["account_name", "region"],
      "cardinality": "1:1",
      "no_match": "keep",
      "source_note": "note",
      "derived_from_note": true
    },
    {
      "id": "R2",
      "kind": "join",
      "description": "Join each trade to Prices on symbol to add closing_price.",
      "source": "trades",
      "lookup": "prices",
      "keys": { "left": ["symbol"], "right": ["symbol"] },
      "columns_added": ["closing_price"],
      "cardinality": "1:1",
      "no_match": null
    },
    {
      "id": "R3",
      "kind": "derive",
      "description": "Derive market_value = quantity * price (the trade price, not closing_price).",
      "output_column": "market_value",
      "how": "arithmetic product of source columns trades.quantity and trades.price (quantity * price); uses the trade price, not the joined closing_price"
    },
    {
      "id": "R4",
      "kind": "filter",
      "description": "Keep only rows where status = SETTLED.",
      "condition": { "column": "status", "operator": "=", "value": "SETTLED" }
    },
    {
      "id": "R5",
      "kind": "schema_validate",
      "description": "Validate that trade_date is a valid date in YYYY-MM-DD format.",
      "columns": [
        { "name": "trade_date", "type": "date", "format": "YYYY-MM-DD" }
      ]
    },
    {
      "id": "R6",
      "kind": "sort",
      "description": "Sort the final output by market_value in descending order (numeric sort).",
      "criteria": [
        { "column": "market_value", "order": "desc", "sort_type": "num" }
      ]
    }
  ],
  "derived_facts": {
    "trades": {
      "trade_id": { "n_distinct": 5, "null_rate": 0.0, "unique": true, "max_group_size": 1 },
      "account_id": { "n_distinct": 4, "null_rate": 0.0, "unique": false, "max_group_size": 2 },
      "symbol": { "n_distinct": 4, "null_rate": 0.0, "unique": false, "max_group_size": 2 },
      "quantity": { "n_distinct": 5, "null_rate": 0.0, "unique": true, "max_group_size": 1 },
      "price": { "n_distinct": 5, "null_rate": 0.0, "unique": true, "max_group_size": 1 },
      "status": { "n_distinct": 2, "null_rate": 0.0, "unique": false, "max_group_size": 4 },
      "trade_date": { "n_distinct": 3, "null_rate": 0.0, "unique": false, "max_group_size": 2 }
    },
    "accounts": {
      "account_id": { "n_distinct": 3, "null_rate": 0.0, "unique": true, "max_group_size": 1 },
      "account_name": { "n_distinct": 3, "null_rate": 0.0, "unique": true, "max_group_size": 1 },
      "region": { "n_distinct": 3, "null_rate": 0.0, "unique": true, "max_group_size": 1 }
    },
    "prices": {
      "symbol": { "n_distinct": 4, "null_rate": 0.0, "unique": true, "max_group_size": 1 },
      "closing_price": { "n_distinct": 4, "null_rate": 0.0, "unique": true, "max_group_size": 1 }
    }
  },
  "outputs": [
    { "name": "trade_positions" }
  ],
  "notes": "Special Handling: A trade whose account_id has no matching account (for example a brand-new account not yet in the Accounts file) must be KEPT in the output with account_name and region left blank - do not drop it.",
  "extra_sections": {},
  "tier": "verified",
  "ambiguities": [
    {
      "rule_id": "R2",
      "issue": "No-match handling for the Prices lookup is unstated: the rule does not say whether a trade whose symbol has no matching price row is kept (with closing_price null-filled) or dropped.",
      "why": "Under the default UNIQUE_MATCH/inner-join behavior an unmatched source row can be silently dropped, changing the output row count. R1 explicitly says keep unmatched, but R2 is silent, so the no_match policy must be human-resolved rather than defaulted."
    }
  ]
}
