  "rules": [
    {
      "id": "R1",
      "kind": "join",
      "description": "Left join each trade to Accounts on account_id to add account_name and region; keep unmatched trades (no-match account_id yields blank account_name and region, do not drop the row)."
    },
    {
      "id": "R2",
      "kind": "join",
      "description": "Join each trade to Prices on symbol to add closing_price."
    },
    {
      "id": "R3",
      "kind": "derive",
      "description": "Derive market_value = quantity * price (the trade price, not closing_price)."
    },
    {
      "id": "R4",
      "kind": "filter",
      "description": "Keep only rows where status = SETTLED."
    },
    {
      "id": "R5",
      "kind": "schema_validate",
      "description": "Validate that trade_date is a valid date in YYYY-MM-DD format."
    },
    {
      "id": "R6",
      "kind": "sort",
      "description": "Sort the final output by market_value in descending order (numeric sort)."
    }
  ],
